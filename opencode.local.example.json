{
  "$schema": "https://opencode.ai/config.json",

  // Local-only profile.
  // Uses local models via llama-swap (DeepSeek R1 for planning, Qwen for building).
  "autoupdate": true,
  "snapshot": false,
  "compaction": { "auto": true, "prune": true },

  "instructions": ["~/.config/opencode/rules/*.md"],

  "plugin": ["@mohak34/opencode-notifier@latest"],

  "model": "llama.cpp/unsloth/Qwen3.6-27B",
  "small_model": "llama.cpp/unsloth/Qwen3.6-27B",

  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-swap (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "local"
      },
      "models": {
        "unsloth/Qwen3.6-27B": {
          "name": "Qwen 3.6 27B"
        },
        "unsloth/DeepSeek-R1-32B": {
          "name": "DeepSeek R1 32B"
        },
        "unsloth/Gemma-4-31B": {
          "name": "Gemma 4 31B"
        }
      }
    }
  },

  "agent": {
    "plan": {
      "mode": "primary",
      "description": "System architect and planner",
      "model": "llama.cpp/unsloth/DeepSeek-R1-32B",
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "permission": {
        "edit": "deny"
      }
    },
    "plan-reviewer": {
      "mode": "primary",
      "model": "llama.cpp/unsloth/Gemma-4-31B",
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "build": {
      "mode": "primary",
      "description": "Senior engineer implementing the plan",
      "model": "llama.cpp/unsloth/Qwen3.6-27B",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },

    // Custom Subagents (defined in agents/*.md)
    "code-reviewer": {
      "model": "llama.cpp/unsloth/Gemma-4-31B",
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "implementer": {
      "model": "llama.cpp/unsloth/Qwen3.6-27B",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },

    // Built-in Subagents
    "general": {
      "model": "llama.cpp/unsloth/Qwen3.6-27B",
      "thinking_level": "medium"
    },
    "explore": {
      "model": "llama.cpp/unsloth/Qwen3.6-27B",
      "thinking_level": "medium"
    },

    // Utility agents stay on Qwen to keep background work fast.
    "title": {
      "model": "llama.cpp/unsloth/Qwen3.6-27B",
      "thinking_level": "low"
    },
    "summary": {
      "model": "llama.cpp/unsloth/Qwen3.6-27B",
      "thinking_level": "low"
    },
    "compaction": {
      "model": "llama.cpp/unsloth/Qwen3.6-27B",
      "thinking_level": "low"
    }
  },

  "mcp": {
    "godoc": {
      "type": "local",
      "command": ["godoc-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        // run for set up --> npx ctx7 setup --opencode
        "CONTEXT7_API_KEY": "your-context7-api-key"
      }
    }
  }
}
