{
  "$schema": "https://opencode.ai/config.json",

  // Hybrid profile.
  // Use GitHub Copilot's strongest OpenAI models for planning and implementation,
  // and Gemini for lighter auxiliary agents where latency/cost matters more.
  "autoupdate": true,
  "snapshot": false,
  "compaction": { "auto": true, "prune": true },

  "instructions": ["~/.config/opencode/rules/*.md"],

  "plugin": [
    "opencode-gemini-auth@latest",
    "@mohak34/opencode-notifier@latest"
  ],

  "disabled_providers": ["google-vertex-anthropic", "google-vertex"],

  "model": "github-copilot/gpt-5.4",
  "small_model": "google/gemini-3-flash-preview",

  "provider": {
    "google": {
      "options": {
        // Replace with your Google Cloud Project ID
        "projectId": "your-google-cloud-project-id"
      }
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "description": "System architect and planner",
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "mode": "primary",
      "description": "Senior engineer implementing the plan",
      "model": "github-copilot/gpt-5.3-codex",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },

    // Custom Subagents (defined in agents/*.md)
    "code-reviewer": {
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "implementer": {
      "model": "github-copilot/gpt-5.3-codex",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },

    // Built-in Subagents
    "general": {
      "model": "google/gemini-3.1-pro-preview",
      "thinking_level": "medium"
    },
    "explore": {
      "model": "google/gemini-3-flash-preview",
      "thinking_level": "medium"
    },

    // Utility agents stay on Gemini Flash to keep background work fast.
    "title": {
      "model": "google/gemini-3-flash-preview",
      "thinking_level": "low"
    },
    "summary": {
      "model": "google/gemini-3-flash-preview",
      "thinking_level": "low"
    },
    "compaction": {
      "model": "google/gemini-3-flash-preview",
      "thinking_level": "low"
    }
  },
  "mcp": {
    "godoc": {
      "type": "local",
      "command": ["godoc-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        // run for set up --> npx ctx7 setup --opencode
        "CONTEXT7_API_KEY": "your-context7-api-key"
      }
    }
  }
}
