{
  "$schema": "https://opencode.ai/config.json",

  // Optimized for GitHub Copilot Subscription
  "autoupdate": true,
  "snapshot": false,
  "compaction": { "auto": true, "prune": true },

  "instructions": ["~/.config/opencode/rules/*.md"],

  "disabled_providers": ["google-vertex-anthropic", "google-vertex"],

  // Default models (GitHub Copilot Provider)
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",

  "agent": {
    // Built-in Primary Agents
    "plan": {
      "mode": "primary",
      "description": "System architect and planner",
      "model": "github-copilot/claude-opus-4.6",
      "thinking": { "type": "adaptive" },
      "effort": "high",
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "mode": "primary",
      "description": "Senior engineer implementing the plan",
      "model": "github-copilot/claude-haiku-4.5",
      "thinking": { "type": "adaptive" },
      "effort": "medium"
    },

    // Custom Subagents (defined in agents/*.md)
    "code-reviewer": {
      "model": "github-copilot/claude-sonnet-4.6",
      "thinking": { "type": "adaptive" },
      "effort": "high"
    },
    "implementer": {
      "model": "github-copilot/claude-haiku-4.5",
      "thinking": { "type": "adaptive" },
      "effort": "medium"
    },

    // Built-in Subagents
    "general": {
      "model": "github-copilot/claude-haiku-4.5",
      "thinking": { "type": "adaptive" },
      "effort": "medium"
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
      "thinking": { "type": "adaptive" },
      "effort": "medium"
    },

    // Utility agents — GPT-5-mini does NOT support temperature.
    // Use reasoningEffort instead.
    "title": {
      "model": "github-copilot/gpt-5-mini",
      "reasoningEffort": "minimal"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini",
      "reasoningEffort": "minimal"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini",
      "reasoningEffort": "minimal"
    }
  },
  // Requires godoc-mcp to be installed and available on PATH
  "mcp": {
    "godoc": {
      "type": "local",
      "command": ["godoc-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        // run for set up --> npx ctx7 setup --opencode
        "CONTEXT7_API_KEY": "your-context7-api-key"
      }
    }
  }
}
