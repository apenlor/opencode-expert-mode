{
  "$schema": "https://opencode.ai/config.json",

  // GitHub Copilot profile.
  // Uses GPT-5.4 for planning/review and GPT-5.3-Codex for implementation.
  // GPT-5.3-Codex is the stable LTS/base choice in Copilot as of 2026.
  "autoupdate": true,
  "snapshot": false,
  "compaction": { "auto": true, "prune": true },

  "instructions": ["~/.config/opencode/rules/*.md"],

  "disabled_providers": ["google-vertex-anthropic", "google-vertex"],

  // Default models (GitHub Copilot Provider)
  "model": "github-copilot/gpt-5.3-codex",
  "small_model": "github-copilot/gpt-5.4-mini",

  "agent": {
    // Built-in Primary Agents
    "plan": {
      "mode": "primary",
      "description": "System architect and planner",
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "mode": "primary",
      "description": "Senior engineer implementing the plan",
      "model": "github-copilot/gpt-5.3-codex",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },

    // Custom Subagents (defined in agents/*.md)
    "code-reviewer": {
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "implementer": {
      "model": "github-copilot/gpt-5.3-codex",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },

    // Built-in Subagents
    "general": {
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },
    "explore": {
      "model": "github-copilot/gpt-5.4-mini",
      "reasoningEffort": "minimal"
    },

    // Utility agents should stay cheap and fast.
    "title": {
      "model": "github-copilot/gpt-5.4-mini",
      "reasoningEffort": "minimal"
    },
    "summary": {
      "model": "github-copilot/gpt-5.4-mini",
      "reasoningEffort": "minimal"
    },
    "compaction": {
      "model": "github-copilot/gpt-5.4-mini",
      "reasoningEffort": "minimal"
    }
  },
  // Requires godoc-mcp to be installed and available on PATH
  "mcp": {
    "godoc": {
      "type": "local",
      "command": ["godoc-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        // run for set up --> npx ctx7 setup --opencode
        "CONTEXT7_API_KEY": "your-context7-api-key"
      }
    }
  }
}
