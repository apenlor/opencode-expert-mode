{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": true,
  "snapshot": false,
  "compaction": { "auto": true, "prune": true },

  "instructions": ["~/.config/opencode/rules/*.md"],

  "plugin": [
    "opencode-gemini-auth@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "disabled_providers": ["google-vertex-anthropic", "google-vertex"],

  // Default models
  "model": "google/gemini-3.1-pro-preview-customtools",
  "small_model": "google/gemini-3-flash-preview",

  "provider": {
    "google": {
      "options": {
        // Replace with your Google Cloud Project ID
        "projectId": "your-google-cloud-project-id"
      }
    }
  },

  "agent": {
    // Built-in Primary Agents
    "plan": {
      "mode": "primary",
      "description": "System architect and planner",
      "model": "google/gemini-3.1-pro-preview-customtools",
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "mode": "primary",
      "description": "Senior engineer implementing the plan",
      "model": "google/gemini-3-flash-preview"
    },

    // Custom Subagents (defined in agent/*.md)
    "code-reviewer": {
      "model": "google/gemini-3.1-pro-preview-customtools"
    },
    "implementer": {
      "model": "google/gemini-3-flash-preview"
    },
    "spec-reviewer": {
      "model": "google/gemini-3.1-pro-preview-customtools"
    },

    // Built-in Subagents
    "general": {
      "model": "google/gemini-3-flash-preview"
    },
    "explore": {
      "model": "google/gemini-3-flash-preview"
    },
    "title": {
      "model": "google/gemini-3-flash-preview"
    },
    "summary": {
      "model": "google/gemini-3-flash-preview"
    },
    "compaction": {
      "model": "google/gemini-3-flash-preview"
    }
  },
  // Requires godoc-mcp to be installed and available on PATH
  "mcp": {
    "godoc": {
      "type": "local",
      "command": ["godoc-mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        // run for set up --> npx ctx7 setup --opencode
        "CONTEXT7_API_KEY": "your-context7-api-key"
      }
    }
  }
}
